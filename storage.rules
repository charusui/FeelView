rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // MVP: require auth. Phase 4: scope to family membership.
      allow read, write: if request.auth != null
        && (request.resource == null  // reads
            || request.resource.size < 52428800); // 50MB max upload
    }
  }
}
